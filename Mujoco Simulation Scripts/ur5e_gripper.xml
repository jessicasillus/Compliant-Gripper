<mujoco model="ur5e_3finger_gripper">
  <!--
    UR5e + 3-Finger Compliant Gripper — Pick & Place Simulation
  -->

  <compiler angle="radian" meshdir="assets" autolimits="true"/>

  <option gravity="0 0 -9.81" timestep="0.001" integrator="implicit"
          solver="Newton" iterations="150" cone="elliptic"
          noslip_iterations="3" noslip_tolerance="1e-6">
    <flag warmstart="enable"/>
  </option>

  <visual>
    <headlight ambient="0.5 0.5 0.5" diffuse="0.8 0.8 0.8"/>
    <rgba haze="0.10 0.18 0.28 1"/>
    <quality shadowsize="4096"/>
    <map znear="0.001"/>
  </visual>

  <default>
    <!-- ═══ UR5e defaults ═══ -->
    <default class="ur5e">
      <material specular="0.5" shininess="0.25"/>
      <joint axis="0 1 0" range="-6.28319 6.28319" armature="0.1"/>
      <general gaintype="fixed" biastype="affine" ctrlrange="-6.2831 6.2831"
        gainprm="2000" biasprm="0 -2000 -400" forcerange="-150 150"/>
      <default class="size3">
        <default class="size3_limited">
          <joint range="-3.1415 3.1415"/>
          <general ctrlrange="-3.1415 3.1415"/>
        </default>
      </default>
      <default class="size1">
        <general gainprm="500" biasprm="0 -500 -100" forcerange="-28 28"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="capsule" group="3"/>
        <default class="eef_collision">
          <geom type="cylinder"/>
        </default>
      </default>
      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
    </default>

    <!-- ═══ Gripper defaults ═══ -->
    <default class="finger_link">
      <geom type="box" density="1100" friction="2.8 0.8 0.02"
            rgba="0.88 0.55 0.10 1" contype="1" conaffinity="1"
            condim="6" solref="0.012 1.0" solimp="0.82 0.95 0.008"
            margin="0.003"/>
    </default>
    <default class="finger_joint_geom">
      <geom type="box" density="1100" contype="1" conaffinity="1"
            condim="6" friction="2.8 0.8 0.02"
            solref="0.012 1.0" solimp="0.82 0.95 0.008"
            margin="0.003"/>
    </default>
    <default class="palm_link">
      <geom type="box" density="1300" friction="2.8 0.8 0.02"
            rgba="0.82 0.50 0.12 1" contype="1" conaffinity="1"
            condim="6" solref="0.012 1.0" solimp="0.82 0.95 0.008"
            margin="0.003"/>
    </default>
    <default class="finger_joint">
      <joint type="hinge" damping="0.018" armature="1e-5"
             limited="true" range="0 3.14"/>
    </default>
    <default class="finger_lip">
      <geom type="sphere" density="0" contype="1" conaffinity="1"
            condim="6" friction="2.8 0.8 0.02"
            solref="0.016 1.0" solimp="0.78 0.92 0.010"
            rgba="0.88 0.55 0.10 0" margin="0.003"/>
    </default>
    <!-- Tray walls: thin collision-enabled boxes -->
    <default class="tray_wall">
      <geom type="box" contype="1" conaffinity="1" friction="0.8 0.3 0.01"/>
    </default>
  </default>

