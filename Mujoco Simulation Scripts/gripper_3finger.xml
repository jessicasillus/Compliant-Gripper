<mujoco model="3finger_compliant_gripper">
  <!--
    3-Finger Compliant Gripper - MuJoCo Model  v9d
    ===============================================
    v9d fix: Improved contact coverage for small cylindrical objects.
      - condim 4→6: enables torsional + rolling friction so objects
        can't twist/rotate out of grip.
      - Lip spheres: 1mm→2mm radius, protrude further for conformity.
      - Added CENTER lip spheres (lip_c, lip_d) at x=0.0225 on each
        link.  Old lips only at tip (x=0.033) left mid-segment gaps
        where flat box face couldn't reach curved objects.  Now 4 lip
        spheres per link = full coverage for cylinders down to ~10mm Ø.
    v9c (retained): noslip_iterations=4, Newton solver, elliptic cone.
    v9b (retained): solref=0.012, solimp=[0.82,0.95,0.008], damp=0.018.
    v9 (retained): splay, TPU friction 2.8, extended closure.
  -->

  <compiler angle="radian" autolimits="true"/>

  <option gravity="0 0 -9.81" timestep="0.0005" integrator="implicit"
          solver="Newton" iterations="200" cone="elliptic"
          noslip_iterations="4" noslip_tolerance="1e-6">
    <flag warmstart="enable"/>
  </option>

  <visual>
    <headlight ambient="0.45 0.45 0.45" diffuse="0.6 0.6 0.6"/>
    <rgba haze="1.0 1.0 1.0 1"/>
    <quality shadowsize="2048"/>
    <map znear="0.001"/>
  </visual>


  <default>
    <!--
      Finger contact compliance — tuned for tendon-driven wrapping.

      solref[0] = time-constant τ (s): contact force ∝ penetration/τ².
        For underactuated wrapping: contact must be STIFF enough to block
        each joint on object contact, redirecting tendon travel to distal
        joints.  0.012 s (was 0.045): firm TPU-on-object contact.
        Too soft → fingers push through; too stiff → bouncing.

      solimp = [dmin, dmax, width, mid, power]
        dmax=0.95: high impedance at depth → joint stops decisively.
        width=0.008: narrow soft→stiff ramp → rapid force build-up.

      margin=0.003: early contact detection (unchanged).
      damping=0.018: slightly higher joint damping for stable wrapping.
    -->
    <default class="finger_link">
      <geom type="box" density="1100" friction="2.8 0.8 0.02"
            rgba="0.88 0.55 0.10 1" contype="1" conaffinity="1"
            condim="6" solref="0.012 1.0" solimp="0.82 0.95 0.008"
            margin="0.003"/>
    </default>
    <default class="finger_joint_geom">
      <geom type="box" density="1100" contype="1" conaffinity="1"
            condim="6" friction="2.8 0.8 0.02"
            solref="0.012 1.0" solimp="0.82 0.95 0.008"
            margin="0.003"/>
    </default>
    <default class="palm_link">
      <geom type="box" density="1300" friction="2.8 0.8 0.02"
            rgba="0.82 0.50 0.12 1" contype="1" conaffinity="1"
            condim="6" solref="0.012 1.0" solimp="0.82 0.95 0.008"
            margin="0.003"/>
    </default>
    <default class="finger_joint">
      <joint type="hinge" damping="0.018" armature="1e-5"
             limited="true" range="0 3.14"/>
    </default>
    <!-- Lip spheres: 2mm radius, 4 per link (tip + center × ±Z).
         Simulate TPU conforming around curved objects.
         condim=6 for full torsional/rolling friction. -->
    <default class="finger_lip">
      <geom type="sphere" density="0" contype="1" conaffinity="1"
            condim="6" friction="2.8 0.8 0.02"
            solref="0.016 1.0" solimp="0.78 0.92 0.010"
            rgba="0.88 0.55 0.10 0" margin="0.003"/>
    </default>
  </default>

  <asset>

    <texture name="white_sky" type="skybox" builtin="gradient" 
             rgb1="1 1 1" rgb2="1 1 1" width="512" height="512"/>
    
    <material name="white_floor" rgba="1 1 1 1" shininess="0" specular="0"/>

    <texture name="grid" type="2d" builtin="checker"
             rgb1="0.92 0.92 0.92" rgb2="0.82 0.82 0.82"
             width="256" height="256"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8"
              reflectance="0.1"/>
    <material name="body_mat" rgba="0.78 0.78 0.80 1"/>
    <material name="body_base_mat" rgba="0.62 0.62 0.64 1"/>
    <material name="joint1_mat" rgba="0.55 0.30 0.05 1"/>
    <material name="joint2_mat" rgba="0.62 0.36 0.08 1"/>
    <material name="joint3_mat" rgba="0.70 0.42 0.10 1"/>
    <material name="object_mat" rgba="0.30 0.70 0.35 0.85" specular="0.3"/>
    <material name="object2_mat" rgba="0.25 0.45 0.80 0.85" specular="0.3"/>
    <material name="object3_mat" rgba="0.80 0.30 0.30 0.85" specular="0.3"/>
    <material name="paper_towel_mat" rgba="0.95 0.93 0.88 1.0" specular="0.05"/>
    <!-- Paint tube (Liquitex Basics): dark body + light cap + teal label band -->
    <material name="paint_tube_mat"     rgba="0.10 0.10 0.10 1.0" specular="0.15"/>
    <material name="paint_tube_label_mat" rgba="0.10 0.55 0.55 1.0" specular="0.20"/>
    <material name="paint_tube_cap_mat" rgba="0.88 0.88 0.88 1.0" specular="0.40"/>
    <!-- Screwdriver: red rubber handle + silver steel shaft -->
    <material name="screwdriver_handle_mat" rgba="0.80 0.18 0.18 1.0" specular="0.10"/>
    <material name="screwdriver_shaft_mat"  rgba="0.80 0.80 0.82 1.0" specular="0.60"/>
    <!-- Tape roll (packing tape): amber body + cardboard core -->
    <material name="tape_roll_mat"  rgba="0.78 0.66 0.29 1.0" specular="0.25"/>
    <material name="tape_core_mat"  rgba="0.54 0.44 0.25 1.0" specular="0.10"/>
  </asset>

  <worldbody>


    <geom name="floor" type="plane" size="0.5 0.5 0.01" material="grid_mat"
          contype="1" conaffinity="1"/>
    <light pos="0 0 0.8" dir="0 0 -1" diffuse="0.7 0.7 0.7" castshadow="true"/>
    <light pos="0.4 0.4 0.6" dir="-0.3 -0.3 -0.5" diffuse="0.4 0.4 0.4"/>

    <!-- === GRIPPER ASSEMBLY  (base at z=0.144, rod_base bottom flush with floor) === -->
    <body name="gripper_base" pos="0 0 0.144">

      <geom name="body_main" type="box" size="0.026 0.022 0.018"
            pos="0 0 -0.030" material="body_mat"
            contype="0" conaffinity="0"/>
      <geom name="body_plate" type="box" size="0.033 0.030 0.005"
            pos="0 0 -0.053" material="body_base_mat"
            contype="0" conaffinity="0"/>
      <geom name="rod" type="cylinder" size="0.006 0.04"
            pos="0 0 -0.098" rgba="0.5 0.5 0.52 1"
            contype="0" conaffinity="0"/>
      <geom name="rod_base" type="cylinder" size="0.018 0.003"
            pos="0 0 -0.141" rgba="0.45 0.45 0.47 1"
            contype="0" conaffinity="0"/>

      <!-- == FINGER A  (parallel, X=-14mm, extends -Y) ==
           Semi-hollow TPU: stiffness = 0.45 x solid
           k0=k1=k2=0.05750  k3=0.07182  N*m/rad
           5 bodies: palm (rigid) → link0 (j0, no sensor) → link1..3 (j1..j3, sensors)
      -->
      <body name="A_palm" pos="-0.014 0.012 0" euler="0 0 -1.5708">
        <joint name="A_splay" type="hinge" axis="0 0 -1"
