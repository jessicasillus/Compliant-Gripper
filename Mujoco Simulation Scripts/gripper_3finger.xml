          <geom name="B_j0_geom" class="finger_joint_geom" material="joint1_mat"
                size="0.0075 0.005 0.001625" pos="0.0075 0 0"/>
          <geom name="B_l0_geom" class="finger_link"
                size="0.0125 0.005 0.006" pos="0.0275 0 0"/>
          <geom name="B_l0_lip_a" class="finger_lip" pos="0.033 0 0.007" size="0.002"/>
          <geom name="B_l0_lip_b" class="finger_lip" pos="0.033 0 -0.007" size="0.002"/>
          <geom name="B_l0_lip_c" class="finger_lip" pos="0.0225 0 0.007" size="0.002"/>
          <geom name="B_l0_lip_d" class="finger_lip" pos="0.0225 0 -0.007" size="0.002"/>
        <body name="B_link1" pos="0.040 0 0">
          <joint name="B_j1" class="finger_joint" axis="0 -1 0"
                 stiffness="0.05750"/>
          <geom name="B_j1_geom" class="finger_joint_geom" material="joint1_mat"
                size="0.0075 0.005 0.001625" pos="0.0075 0 0"/>
          <geom name="B_l1_geom" class="finger_link"
                size="0.0125 0.005 0.006" pos="0.0275 0 0"/>
          <geom name="B_l1_lip_a" class="finger_lip" pos="0.033 0 0.007" size="0.002"/>
          <geom name="B_l1_lip_b" class="finger_lip" pos="0.033 0 -0.007" size="0.002"/>
          <geom name="B_l1_lip_c" class="finger_lip" pos="0.0225 0 0.007" size="0.002"/>
          <geom name="B_l1_lip_d" class="finger_lip" pos="0.0225 0 -0.007" size="0.002"/>
          <site name="B_force1" pos="0.0275 0 0.012" size="0.008" rgba="1 0 0 0"/>
          <body name="B_link2" pos="0.040 0 0">
