          </body>    <!-- /B_link2 -->
        </body>      <!-- /B_link1 -->
        </body>      <!-- /B_link0 -->
      </body>        <!-- /B_palm -->

      <!-- == FINGER C  (opposing, X=0, extends +Y) == -->
