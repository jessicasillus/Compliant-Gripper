    <body name="obj_paint_tube" pos="0.0 0.22 0.017" euler="0 1.5708 0">
      <freejoint name="obj_paint_tube_jnt"/>
      <geom name="obj_pt_body" type="cylinder"
            size="0.017 0.055"
            density="900" material="paint_tube_mat"
            friction="1.1 0.5 0.01" contype="1" conaffinity="1"
            condim="6" solref="0.008 1.0" solimp="0.92 0.98 0.001"/>
      <geom name="obj_pt_label" type="cylinder"
            size="0.0173 0.022" pos="0 0 -0.005"
            density="0" material="paint_tube_label_mat"
            contype="0" conaffinity="0"/>
      <!-- crimp/shoulder/nozzle/cap: visual-only — disabling collision on these
           small adjacent geoms eliminates the multi-contact oscillation that
           caused the tube to vibrate and eject from the grip.
           Only the main body cylinder (obj_pt_body) needs physics contact. -->
      <geom name="obj_pt_crimp" type="box"
            size="0.0015 0.015 0.005" pos="0 0 -0.059"
            density="1200" material="paint_tube_mat"
            contype="0" conaffinity="0"/>
      <geom name="obj_pt_shoulder" type="cylinder"
            size="0.011 0.006" pos="0 0 0.061"
            density="900" material="paint_tube_mat"
            contype="0" conaffinity="0"/>
      <geom name="obj_pt_nozzle" type="cylinder"
            size="0.005 0.005" pos="0 0 0.072"
            density="900" material="paint_tube_mat"
            contype="0" conaffinity="0"/>
      <geom name="obj_pt_cap" type="cylinder"
            size="0.0075 0.005" pos="0 0 0.082"
            density="900" material="paint_tube_cap_mat"
            contype="0" conaffinity="0"/>
    </body>

    <!-- Screwdriver — ALL offsets along Z_local (euler 0 1.5708 0 → axis=Z_local)
         handle r=12.7mm hl=25mm [−25,+25] | ferrule r=6mm [+25,+33] |
         shaft r=1.5mm hl=31mm [+33,+95] | grip ridge visual-only at z=−5
    -->
    <body name="obj_screwdriver" pos="0.18 0.22 0.013" euler="0 1.5708 0">
      <freejoint name="obj_screwdriver_jnt"/>
      <geom name="obj_sd_handle" type="cylinder"
            size="0.0127 0.025"
            density="1100" material="screwdriver_handle_mat"
            friction="1.8 0.8 0.01" contype="1" conaffinity="1"
            condim="6" solref="0.008 1.0" solimp="0.92 0.98 0.001"/>
      <geom name="obj_sd_grip" type="cylinder"
            size="0.014 0.002" pos="0 0 -0.005"
            density="0" material="screwdriver_handle_mat"
            contype="0" conaffinity="0"/>
      <geom name="obj_sd_ferrule" type="cylinder"
            size="0.006 0.004" pos="0 0 0.029"
            density="7800" material="screwdriver_shaft_mat"
            friction="0.8 0.3 0.01" contype="1" conaffinity="1"
            condim="6" solref="0.005 1.0"/>
      <geom name="obj_sd_shaft" type="cylinder"
            size="0.0015 0.031" pos="0 0 0.064"
            density="7800" material="screwdriver_shaft_mat"
            friction="0.8 0.3 0.01" contype="1" conaffinity="1"
            condim="6" solref="0.005 1.0"/>
    </body>

    <!-- Tape Roll  (3.75 in OD × 3 in ID × 2 in thick)
         outer_r = 47.6 mm,  inner_r = 38.1 mm,  thickness = 50.8 mm
         MuJoCo cannot represent a true annulus; the outer cylinder is the
         contact surface.  The inner core cylinder is purely visual (no collision).
         Park: upright (hole axis = Z), z = half_thickness = 25.4 mm
    -->
    <body name="obj_tape_roll" pos="0.0 -0.22 0.0254">
      <freejoint name="obj_tape_roll_jnt"/>
      <!-- Outer tape surface (amber/yellow) -->
      <geom name="obj_tr_outer" type="cylinder"
            size="0.047625 0.0254"
            density="600" material="tape_roll_mat"
            friction="1.4 0.6 0.01" contype="1" conaffinity="1"
            condim="6" solref="0.008 1.0" solimp="0.92 0.98 0.001"/>
      <!-- Inner cardboard core (visual only — no collision) -->
      <geom name="obj_tr_core" type="cylinder"
            size="0.0381 0.0255"
            density="0" material="tape_core_mat"
            contype="0" conaffinity="0"/>
    </body>

  </worldbody>

  <!-- === TENDONS === -->
  <tendon>
    <fixed name="tendon_A" limited="true" range="0 0.090">
      <joint joint="A_j0" coef="0.0050"/>
      <joint joint="A_j1" coef="0.0050"/>
      <joint joint="A_j2" coef="0.0050"/>
      <joint joint="A_j3" coef="0.0050"/>
    </fixed>
    <fixed name="tendon_B" limited="true" range="0 0.090">
      <joint joint="B_j0" coef="0.0050"/>
      <joint joint="B_j1" coef="0.0050"/>
      <joint joint="B_j2" coef="0.0050"/>
      <joint joint="B_j3" coef="0.0050"/>
    </fixed>
    <fixed name="tendon_C" limited="true" range="0 0.090">
      <joint joint="C_j0" coef="0.0050"/>
      <joint joint="C_j1" coef="0.0050"/>
      <joint joint="C_j2" coef="0.0050"/>
      <joint joint="C_j3" coef="0.0050"/>
    </fixed>
  </tendon>

  <!-- === ACTUATORS  (tuned to match real ST3215 servo forces) === -->
  <actuator>
    <position name="act_A_pos" tendon="tendon_A"
              kp="2000" kv="50"
              ctrlrange="0 0.090" forcerange="-20 20"/>
    <position name="act_B_pos" tendon="tendon_B"
              kp="2000" kv="50"
              ctrlrange="0 0.090" forcerange="-20 20"/>
    <position name="act_C_pos" tendon="tendon_C"
              kp="2000" kv="50"
              ctrlrange="0 0.090" forcerange="-20 20"/>

    <general name="act_A_frc" tendon="tendon_A"
             gainprm="1 0 0" biasprm="0 0 0"
             ctrlrange="-10 10" forcerange="-20 20"
             dyntype="none"/>
    <general name="act_B_frc" tendon="tendon_B"
             gainprm="1 0 0" biasprm="0 0 0"
             ctrlrange="-10 10" forcerange="-20 20"
             dyntype="none"/>
    <general name="act_C_frc" tendon="tendon_C"
             gainprm="1 0 0" biasprm="0 0 0"
             ctrlrange="-10 10" forcerange="-20 20"
             dyntype="none"/>

    <!-- Splay actuators: parallel fingers A & B rotate outward -->
    <position name="act_A_splay" joint="A_splay"
              kp="500" kv="20"
              ctrlrange="0 0.5236" forcerange="-10 10"/>
    <position name="act_B_splay" joint="B_splay"
              kp="500" kv="20"
              ctrlrange="0 0.5236" forcerange="-10 10"/>
  </actuator>

  <!-- === SENSORS === -->
  <!-- j0 (palm joint): cable-driven but NOT instrumented with a flex sensor
       on the physical prototype. Joint-position sensors added here so
       the simulation can track palm deflection; forces at this segment
       are flagged as "unmonitored" in the Python readout. -->
  <sensor>
    <jointpos name="A_j0_pos" joint="A_j0"/>
    <jointpos name="A_j1_pos" joint="A_j1"/>
    <jointpos name="A_j2_pos" joint="A_j2"/>
    <jointpos name="A_j3_pos" joint="A_j3"/>
    <jointpos name="B_j0_pos" joint="B_j0"/>
    <jointpos name="B_j1_pos" joint="B_j1"/>
    <jointpos name="B_j2_pos" joint="B_j2"/>
    <jointpos name="B_j3_pos" joint="B_j3"/>
    <jointpos name="C_j0_pos" joint="C_j0"/>
    <jointpos name="C_j1_pos" joint="C_j1"/>
    <jointpos name="C_j2_pos" joint="C_j2"/>
    <jointpos name="C_j3_pos" joint="C_j3"/>
    <tendonpos name="ten_A_len" tendon="tendon_A"/>
    <tendonpos name="ten_B_len" tendon="tendon_B"/>
    <tendonpos name="ten_C_len" tendon="tendon_C"/>
    <touch name="A_touch1" site="A_force1"/>
    <touch name="A_touch2" site="A_force2"/>
    <touch name="A_touch3" site="A_force3"/>
    <touch name="B_touch1" site="B_force1"/>
    <touch name="B_touch2" site="B_force2"/>
    <touch name="B_touch3" site="B_force3"/>
    <touch name="C_touch1" site="C_force1"/>
    <touch name="C_touch2" site="C_force2"/>
    <touch name="C_touch3" site="C_force3"/>
  </sensor>

  <!-- Contact exclusions -->
  <!-- Adjacent bodies (parent-child) -->
  <contact>
    <!-- A finger chain -->
    <exclude body1="A_palm"  body2="A_link0"/>
    <exclude body1="A_link0" body2="A_link1"/>
    <exclude body1="A_link1" body2="A_link2"/>
    <exclude body1="A_link2" body2="A_link3"/>
    <!-- B finger chain -->
    <exclude body1="B_palm"  body2="B_link0"/>
    <exclude body1="B_link0" body2="B_link1"/>
    <exclude body1="B_link1" body2="B_link2"/>
    <exclude body1="B_link2" body2="B_link3"/>
    <!-- C finger chain -->
    <exclude body1="C_palm"  body2="C_link0"/>
    <exclude body1="C_link0" body2="C_link1"/>
    <exclude body1="C_link1" body2="C_link2"/>
    <exclude body1="C_link2" body2="C_link3"/>
    <!-- gripper_base ↔ proximal bodies -->
    <exclude body1="gripper_base" body2="A_palm"/>
    <exclude body1="gripper_base" body2="B_palm"/>
    <exclude body1="gripper_base" body2="C_palm"/>
    <exclude body1="gripper_base" body2="A_link0"/>
    <exclude body1="gripper_base" body2="B_link0"/>
    <exclude body1="gripper_base" body2="C_link0"/>
    <exclude body1="gripper_base" body2="A_link1"/>
    <exclude body1="gripper_base" body2="B_link1"/>
    <exclude body1="gripper_base" body2="C_link1"/>
    <!-- palm-to-palm (A/B are side-by-side) -->
    <exclude body1="A_palm" body2="B_palm"/>
    <exclude body1="A_palm" body2="C_palm"/>
    <exclude body1="B_palm" body2="C_palm"/>
    <!-- link0-to-link0 cross-finger (all three close at base) -->
    <exclude body1="A_link0" body2="B_link0"/>
    <exclude body1="A_link0" body2="C_link0"/>
    <exclude body1="B_link0" body2="C_link0"/>
  </contact>

</mujoco>