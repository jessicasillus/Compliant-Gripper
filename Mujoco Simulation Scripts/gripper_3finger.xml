          <geom name="B_l2_lip_d" class="finger_lip" pos="0.0225 0 -0.007" size="0.002"/>
            <site name="B_force2" pos="0.0275 0 0.012" size="0.008" rgba="1 0 0 0"/>
            <body name="B_link3" pos="0.040 0 0">
              <joint name="B_j3" class="finger_joint" axis="0 -1 0"
                     stiffness="0.07182"/>
              <geom name="B_j3_geom" class="finger_joint_geom" material="joint3_mat"
                    size="0.0075 0.005 0.00175" pos="0.0075 0 0"/>
              <geom name="B_l3_geom" class="finger_link"
                    size="0.0125 0.005 0.006" pos="0.0275 0 0"/>
              <geom name="B_l3_lip_a" class="finger_lip" pos="0.033 0 0.007" size="0.002"/>
              <geom name="B_l3_lip_b" class="finger_lip" pos="0.033 0 -0.007" size="0.002"/>
          <geom name="B_l3_lip_c" class="finger_lip" pos="0.0225 0 0.007" size="0.002"/>
          <geom name="B_l3_lip_d" class="finger_lip" pos="0.0225 0 -0.007" size="0.002"/>
