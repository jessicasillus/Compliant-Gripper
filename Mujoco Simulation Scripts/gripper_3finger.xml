          <geom name="A_j1_geom" class="finger_joint_geom" material="joint1_mat"
                size="0.0075 0.005 0.001625" pos="0.0075 0 0"/>
          <geom name="A_l1_geom" class="finger_link"
                size="0.0125 0.005 0.006" pos="0.0275 0 0"/>
          <geom name="A_l1_lip_a" class="finger_lip" pos="0.033 0 0.007" size="0.002"/>
