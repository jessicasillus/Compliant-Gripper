          <geom name="A_l1_lip_c" class="finger_lip" pos="0.0225 0 0.007" size="0.002"/>
          <geom name="A_l1_lip_d" class="finger_lip" pos="0.0225 0 -0.007" size="0.002"/>
          <site name="A_force1" pos="0.0275 0 0.012" size="0.008" rgba="1 0 0 0"/>
          <body name="A_link2" pos="0.040 0 0">
            <joint name="A_j2" class="finger_joint" axis="0 -1 0"
